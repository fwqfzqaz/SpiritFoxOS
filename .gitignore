# SpiritFoxOS - .gitignore

# Build output
build/

# Generated header (from logo.png)
kernel/include/logo_data.h

# Binary packages (large, non-source)
cs/*.deb
cs/*.jar

# Disk images
*.img
*.iso

# Object files
*.o
*.elf
*.bin

# Log files
*.log

# Auto commit script (local only)
auto_commit.sh

# Tools / JAR
*.jar

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Python cache
__pycache__/
*.pyc